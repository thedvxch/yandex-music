{
  "$schema": "https://typedoc.org/schema.json",
  "name": "@dvxch/yandex-music",
  "entryPoints": ["src/index.ts"],
  "out": "docs/api",
  "tsconfig": "tsconfig.build.json",
  "excludeInternal": true,
  "readme": "README.md",
  "projectDocuments": [
    "docs/guides/01-getting-started.md",
    "docs/guides/02-architecture.md",
    "docs/guides/03-endpoints.md",
    "docs/guides/04-realtime.md",
    "docs/guides/05-examples.md"
  ],
  "githubPages": true,
  "customCss": "docs/theme.css",
  "customJs": "docs/theme.js",
  "favicon": "assets/favicon.svg",
  "customFooterHtml": "<a href=\"https://www.npmjs.com/package/@dvxch/yandex-music\">@dvxch/yandex-music</a> · независимый TypeScript-клиент Yandex Music API · MIT",
  "navigationLinks": {
    "Документация": "https://gh.dvxch.link/yandex-music/",
    "npm": "https://www.npmjs.com/package/@dvxch/yandex-music",
    "GitHub": "https://github.com/thedvxch/yandex-music"
  },
  "categorizeByGroup": true,
  "navigation": {
    "includeCategories": true,
    "includeGroups": true,
    "compactFolders": true
  },
  "sort": ["kind", "alphabetical"],
  "kindSortOrder": [
    "Class",
    "Interface",
    "TypeAlias",
    "Function",
    "Variable",
    "Enum",
    "Reference"
  ],
  "visibilityFilters": {
    "protected": false,
    "private": false,
    "inherited": true,
    "external": false
  }
}
